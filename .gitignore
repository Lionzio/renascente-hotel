$gitignoreContent = @'
# Node / Vite (Frontend)
node_modules/
dist/
build/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.eslintcache

# Python / FastAPI (Backend)
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.coverage
htmlcov/
.Pipfile.lock

# Ambientes Virtuais
venv/
env/
ENV/
.venv/

# Variáveis de Ambiente e Credenciais (CRÍTICO)
.env
.env.local
.env.*.local

# IDEs e OS
.vscode/
.idea/
.DS_Store
Thumbs.db
'@
Set-Content -Path ".gitignore" -Value $gitignoreContent -Encoding UTF8